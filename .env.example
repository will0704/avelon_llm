# Environment
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# CORS - Backend URL
BACKEND_URL=http://localhost:3000

# API Key for backend-to-LLM communication
API_KEY=dev-api-key-change-in-production

# Model Paths (will be populated when models are trained)
# CLASSIFIER_MODEL_PATH=app/models/document_classifier/weights/classifier.pt
# NER_MODEL_PATH=app/models/ner_extractor/weights/ner.pt
# FRAUD_MODEL_PATH=app/models/fraud_detector/weights/fraud.pt
# SCORER_MODEL_PATH=app/models/credit_scorer/weights/scorer.pkl

# OCR Configuration (Windows: path to tesseract.exe)
# TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# NER Model (HuggingFace model name)
NER_MODEL_NAME=dslim/bert-base-NER

# Processing Thresholds
CONFIDENCE_THRESHOLD=0.7
FRAUD_THRESHOLD=0.4

